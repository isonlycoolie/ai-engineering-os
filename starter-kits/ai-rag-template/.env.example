# Application
APP_ENV=development
LOG_LEVEL=INFO

# Vector store (stub — swap for Pinecone, pgvector, Chroma, etc.)
VECTOR_STORE_PATH=./data/vector_store
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# LLM (stub — wire to your provider)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-replace-me

# Retrieval
RETRIEVAL_TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Evaluation
EVAL_ENABLED=true
EVAL_OUTPUT_DIR=./data/eval
