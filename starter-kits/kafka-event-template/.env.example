# Application
APP_ENV=development
LOG_LEVEL=INFO

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=domain.events.v1
KAFKA_CONSUMER_GROUP=domain-service
KAFKA_CLIENT_ID=domain-service-1

# Idempotency store (stub — use Redis or DB in production)
IDEMPOTENCY_STORE_PATH=./data/idempotency

# Dead letter queue topic (see docs/architecture.md)
KAFKA_DLQ_TOPIC=domain.events.v1.dlq

# Schema
EVENT_SCHEMA_VERSION=1
